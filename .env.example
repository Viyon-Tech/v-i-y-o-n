# VIYON secrets — copy to .env and fill in. NEVER commit .env. NEVER log these values.

# Anthropic API key — LLM brain (anthropic SDK)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ElevenLabs API key — text-to-speech
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Picovoice access key — wake-word detection (pvporcupine)
PICOVOICE_ACCESS_KEY=your-picovoice-access-key-here

# Brave Search API key — web research (PULSE)
BRAVE_API_KEY=your-brave-api-key-here
